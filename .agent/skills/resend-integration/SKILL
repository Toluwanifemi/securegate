/**
 * Resend Webhook Handler
 *
 * Endpoint: POST /api/webhooks/resend
 *
 * Handles delivery events from Resend: email.delivered, email.bounced,
 * email.complained. Each event is verified via Svix signature before processing.
 *
 * Setup:
 * 1. Install: npm install svix
 * 2. Add RESEND_WEBHOOK_SECRET to your environment variables
 *    (found in Resend dashboard → Webhooks)
 * 3. Register this endpoint URL in your Resend dashboard
 */

import { NextRequest, NextResponse } from "next/server";
import { Webhook } from "svix";

// ─────────────────────────────────────────────
// Types
// ─────────────────────────────────────────────

interface ResendWebhookEvent {
  type: "email.delivered" | "email.bounced" | "email.complained" | string;
  data: {
    email_id: string;
    from: string;
    to: string[];
    subject: string;
    created_at: string;
  };
}

// ─────────────────────────────────────────────
// Handler
// ─────────────────────────────────────────────

export async function POST(req: NextRequest): Promise<NextResponse> {
  const webhookSecret = process.env.RESEND_WEBHOOK_SECRET;

  if (!webhookSecret) {
    console.error("[RESEND_WEBHOOK] RESEND_WEBHOOK_SECRET is not set");
    return NextResponse.json({ error: "Server misconfiguration" }, { status: 500 });
  }

  // ── 1. Read the raw body ──────────────────────────────────────────────────
  const rawBody = await req.text();

  // ── 2. Extract Svix signature headers ────────────────────────────────────
  const svixId = req.headers.get("svix-id");
  const svixTimestamp = req.headers.get("svix-timestamp");
  const svixSignature = req.headers.get("svix-signature");

  if (!svixId || !svixTimestamp || !svixSignature) {
    console.warn("[RESEND_WEBHOOK] Missing Svix signature headers");
    return NextResponse.json({ error: "Missing signature headers" }, { status: 400 });
  }

  // ── 3. Verify the signature ───────────────────────────────────────────────
  let event: ResendWebhookEvent;

  try {
    const wh = new Webhook(webhookSecret);
    event = wh.verify(rawBody, {
      "svix-id": svixId,
      "svix-timestamp": svixTimestamp,
      "svix-signature": svixSignature,
    }) as ResendWebhookEvent;
  } catch (error) {
    console.error("[RESEND_WEBHOOK] Signature verification failed:", error);
    return NextResponse.json({ error: "Invalid signature" }, { status: 401 });
  }

  // ── 4. Handle events ──────────────────────────────────────────────────────
  const { type, data } = event;

  console.info(`[RESEND_WEBHOOK] Event received: ${type}`, {
    email_id: data.email_id,
    to: data.to,
    subject: data.subject,
  });

  switch (type) {
    case "email.delivered":
      await handleDelivered(data);
      break;

    case "email.bounced":
      await handleBounced(data);
      break;

    case "email.complained":
      await handleComplained(data);
      break;

    default:
      // Log unknown events but return 200 so Resend does not retry them
      console.info(`[RESEND_WEBHOOK] Unhandled event type: ${type}`);
  }

  return NextResponse.json({ received: true }, { status: 200 });
}

// ─────────────────────────────────────────────
// Event Handlers
// ─────────────────────────────────────────────

/**
 * Called when an email is successfully delivered.
 * Extend this to update a delivery status in the database if needed.
 */
async function handleDelivered(
  data: ResendWebhookEvent["data"]
): Promise<void> {
  console.info(`[RESEND_WEBHOOK] Email delivered to ${data.to.join(", ")}`);
  // Optional: db.emailLog.update({ where: { resendId: data.email_id }, data: { status: "delivered" } })
}

/**
 * Called when an email bounces.
 * Consider flagging the user's email as invalid to prevent future sends.
 */
async function handleBounced(
  data: ResendWebhookEvent["data"]
): Promise<void> {
  console.warn(`[RESEND_WEBHOOK] Email bounced for ${data.to.join(", ")}`);
  // Optional: mark the user's email as bounced in the database
  // This prevents sending further emails to an undeliverable address
}

/**
 * Called when a recipient marks the email as spam.
 * Important: stop sending to this address immediately to protect sender reputation.
 */
async function handleComplained(
  data: ResendWebhookEvent["data"]
): Promise<void> {
  console.warn(`[RESEND_WEBHOOK] Spam complaint from ${data.to.join(", ")}`);
  // Important: unsubscribe / suppress this email address
  // Continuing to send to complainants damages your sender reputation
}